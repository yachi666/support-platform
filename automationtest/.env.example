AUTOTEST_BASE_URL=http://127.0.0.1:5173
AUTOTEST_API_BASE_URL=http://127.0.0.1:8080/api
AUTOTEST_DB_URL=postgresql://localhost:5432/support
AUTOTEST_DEFAULT_TIMEOUT_MS=15000
AUTOTEST_TRACE=retain-on-failure
AUTOTEST_WORKERS=1

# Primary smoke user
AUTOTEST_STAFF_ID=123456
AUTOTEST_PASSWORD=12345678

# Optional role-specific users for future permission regression coverage
AUTOTEST_ADMIN_STAFF_ID=
AUTOTEST_ADMIN_PASSWORD=
AUTOTEST_EDITOR_STAFF_ID=
AUTOTEST_EDITOR_PASSWORD=
AUTOTEST_READONLY_STAFF_ID=
AUTOTEST_READONLY_PASSWORD=

# Optional expectations for manual/shared test data
AUTOTEST_EXPECTED_TEAM_NAME=
AUTOTEST_EXPECTED_WORKSPACE_TITLE=
